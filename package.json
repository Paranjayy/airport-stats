{
  "name": "airport-stats",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "db:setup": "python3 scripts/setup_database.py",
    "db:seed": "python3 scripts/seed_data.py",
